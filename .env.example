# =============================================================================
# RentCRM Pro — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running setup.sh
# Never commit .env to version control — it contains secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Full connection URL used by Prisma (must match POSTGRES_* vars below)
DATABASE_URL=postgresql://rentcrm:CHANGE_ME@postgres:5432/rentcrm

# PostgreSQL container credentials (must match DATABASE_URL above)
POSTGRES_DB=rentcrm
POSTGRES_USER=rentcrm
POSTGRES_PASSWORD=CHANGE_ME        # Generate with: openssl rand -hex 32


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME           # Generate with: openssl rand -hex 32


# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME               # Generate with: openssl rand -hex 64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME       # Generate with: openssl rand -hex 64
JWT_REFRESH_EXPIRES_IN=7d


# -----------------------------------------------------------------------------
# Server ports (host-side)
# Change these if the default ports are already in use on your server.
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
API_PORT=3001


# -----------------------------------------------------------------------------
# Public URLs
# Replace YOUR_IP_OR_DOMAIN with your server's IP address or domain name.
# These must be reachable from the browser (not Docker-internal hostnames).
# Examples:
#   http://192.168.1.100:3000
#   https://rentcrm.example.com
# -----------------------------------------------------------------------------
FRONTEND_URL=http://YOUR_IP_OR_DOMAIN:3000
VITE_API_URL=http://YOUR_IP_OR_DOMAIN:3001


# -----------------------------------------------------------------------------
# Email (SMTP) — optional, required for checkin links and contract signing
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=RentCRM Pro <no-reply@example.com>


# -----------------------------------------------------------------------------
# LibreTranslate (self-hosted, internal Docker hostname — do not change)
# -----------------------------------------------------------------------------
LIBRETRANSLATE_URL=http://libretranslate:5000


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
