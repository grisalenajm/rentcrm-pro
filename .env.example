# =============================================================================
# RentalSuite — Environment Variables
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked CHANGE_ME
# 3. Never commit .env to version control — it contains secrets
# =============================================================================


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# DATABASE_URL is constructed automatically by docker-compose.yml from
# POSTGRES_PASSWORD — you do NOT need to set it here.
POSTGRES_DB=rentcrm
POSTGRES_USER=rentcrm
POSTGRES_PASSWORD=CHANGE_ME          # generate: openssl rand -hex 32


# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_URL is constructed automatically by docker-compose.yml from
# REDIS_PASSWORD — you do NOT need to set it here.
REDIS_PASSWORD=CHANGE_ME             # generate: openssl rand -hex 32


# ── Authentication (JWT) ──────────────────────────────────────────────────────
# Long random string used to sign access tokens.
JWT_SECRET=CHANGE_ME                 # generate: openssl rand -hex 64
JWT_EXPIRES_IN=15m
# NOTE: refresh token endpoint (/auth/refresh) is not yet implemented.
# JWT_REFRESH_SECRET and JWT_REFRESH_EXPIRES_IN are reserved for future use.


# ── Public URLs ───────────────────────────────────────────────────────────────
# URLs reachable from the browser.  Use your domain with https:// when running
# behind a reverse proxy (e.g. Nginx + Let's Encrypt).
# Local example : http://192.168.1.100:3000
# Production    : https://rentalsuite.example.com
FRONTEND_URL=https://YOUR_DOMAIN
VITE_API_URL=https://YOUR_DOMAIN     # same as FRONTEND_URL when behind Nginx


# ── Server Ports ──────────────────────────────────────────────────────────────
# Host-side ports exposed by Docker.  The external Nginx reverse proxy connects
# to these.  Change only if the defaults are already in use on your server.
FRONTEND_PORT=3000
API_PORT=3001


# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production


# ── LibreTranslate ────────────────────────────────────────────────────────────
# Internal Docker service URL.  Do not change unless you use an external
# LibreTranslate instance.
LIBRETRANSLATE_URL=http://libretranslate:5000


# ── SMTP (Email) ──────────────────────────────────────────────────────────────
# Used for check-in links, contract delivery, and recurring-expense notifications.
# Leave blank to disable email features.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=RentalSuite <no-reply@example.com>


# ── API Public URL ────────────────────────────────────────────────────────────
# Externally reachable URL of the API (with https:// when behind a reverse proxy).
# Used for: Paperless-ngx webhook callbacks, check-in links sent by email, and
# any other context where the API URL must be resolvable from outside Docker.
# Example: https://api.rentalsuite.example.com  or  https://rentalsuite.example.com
API_PUBLIC_URL=https://YOUR_DOMAIN


# ── Paperless-ngx (optional) ──────────────────────────────────────────────────
# When set, signed contracts are automatically uploaded to your Paperless-ngx
# instance after the tenant completes digital signing.
# Leave blank to disable this integration.
PAPERLESS_URL=https://paperless.example.com
PAPERLESS_TOKEN=CHANGE_ME
