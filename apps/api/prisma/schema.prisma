generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  nif       String?  @db.VarChar(20)
  address   String?  @db.Text
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(255)
  logo      String?  @db.Text
  smtpHost  String?  @map("smtp_host") @db.VarChar(255)
  smtpPort  Int?     @map("smtp_port")
  smtpUser  String?  @map("smtp_user") @db.VarChar(255)
  smtpPass  String?  @map("smtp_pass") @db.VarChar(255)
  smtpFrom  String?  @map("smtp_from") @db.VarChar(255)
  currency  String?  @default("EUR") @db.VarChar(10)
  dateFormat String? @default("dd/MM/yyyy") @map("date_format") @db.VarChar(20)
  sesUsuarioWs        String?  @map("ses_usuario_ws") @db.VarChar(100)
  sesPasswordWs       String?  @map("ses_password_ws") @db.VarChar(100)
  sesCodigoArrendador String?  @map("ses_codigo_arrendador") @db.VarChar(20)
  sesCodigoEstablecimiento String? @map("ses_codigo_establecimiento") @db.VarChar(20)
  sesEndpoint         String?  @map("ses_endpoint") @db.VarChar(255)
  sesEntorno          String?  @map("ses_entorno") @db.VarChar(20)
  publicUrl           String?  @map("public_url") @db.VarChar(255)
  publicBaseUrl       String?  @map("public_base_url") @db.VarChar(255)
  paperlessUrl        String?  @map("paperless_url") @db.VarChar(255)
  paperlessToken      String?  @map("paperless_token") @db.VarChar(500)
  paperlessSecret     String?  @map("paperless_secret") @db.VarChar(255)
  paperlessDocTypeId  Int?     @map("paperless_doc_type_id")
  bankSwift           String?  @map("bank_swift") @db.VarChar(20)
  bankIban            String?  @map("bank_iban") @db.VarChar(50)
  bankBeneficiary     String?  @map("bank_beneficiary") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  properties          Property[]
  clients             Client[]
  bookings            Booking[]
  financials          Financial[]
  policeReports       PoliceReport[]
  auditLogs           AuditLog[]
  financialCategories FinancialCategory[]
  contractTemplates   ContractTemplate[]
  contracts           Contract[]
  propertyContents    PropertyContent[]
  propertyDocuments   PropertyDocument[]
  recurringExpenses   RecurringExpense[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  role           String    @db.VarChar(20)
  isActive          Boolean   @default(true) @map("is_active")
  passwordChangedAt DateTime? @map("password_changed_at")
  otpSecret         String?   @map("otp_secret") @db.VarChar(255)
  otpEnabled        Boolean   @default(false) @map("otp_enabled")
  otpVerifiedAt     DateTime? @map("otp_verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertiesCreated Property[]         @relation("PropertyCreatedBy")
  clientsCreated    Client[]           @relation("ClientCreatedBy")
  bookingsCreated   Booking[]          @relation("BookingCreatedBy")
  financialsCreated Financial[]        @relation("FinancialCreatedBy")
  evaluations       ClientEvaluation[]
  policeReportsSent PoliceReport[]     @relation("PoliceReportSentBy")
  auditLogs         AuditLog[]
  stockMovements    StockMovement[]

  @@index([organizationId])
  @@map("users")
}

model Property {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(255)
  address        String    @db.Text
  city           String    @db.VarChar(100)
  province       String    @db.VarChar(100)
  postalCode     String?   @map("postal_code") @db.VarChar(10)
  country        String?   @map("country") @db.VarChar(5)
  rooms          Int
  bathrooms      Int?
  maxGuests      Int?      @map("max_guests")
  pricePerNight  Decimal?  @map("price_per_night") @db.Decimal(10, 2)
  photo          String?   @db.Text
  status         String    @default("active") @db.VarChar(20)
  sesCodigoEstablecimiento String? @map("ses_codigo_establecimiento") @db.VarChar(20)
  nrua           String?   @map("nrua") @db.VarChar(80)
  purchasePrice  Float?    @map("purchase_price")
  paperlessCorrespondentId   Int?    @map("paperless_correspondent_id")
  cadastralRef   String?   @map("cadastral_ref") @db.VarChar(100)
  notes          String?   @db.Text
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator            User?              @relation("PropertyCreatedBy", fields: [createdBy], references: [id])
  bookings           Booking[]
  financials         Financial[]
  availabilitySyncs  AvailabilitySync[]
  availabilityBlocks AvailabilityBlock[]
  expenses           Expense[]
  propertyContents   PropertyContent[]
  propertyDocuments  PropertyDocument[]
  propertyRules      PropertyRules?
  recurringExpenses  RecurringExpense[]
  stockMovements     StockMovement[]

  @@index([organizationId])
  @@map("properties")
}

model Expense {
  id         Int      @id @default(autoincrement())
  propertyId String   @map("property_id") @db.Uuid
  property   Property @relation(fields: [propertyId], references: [id])
  date       DateTime
  amount     Float
  type       String
  notes      String?
  deductible Boolean  @default(false)
  paperlessDocumentId Int?   @map("paperless_document_id")
  paperlessAmount     Float? @map("paperless_amount")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([propertyId])
  @@map("expenses")
}

model Client {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  firstName      String    @map("first_name") @db.VarChar(100)
  lastName       String    @map("last_name") @db.VarChar(100)
  dniPassport    String?   @map("dni_passport") @db.VarChar(20)
  nationality    String?   @db.VarChar(100)
  birthDate      DateTime? @map("birth_date") @db.Date
  email          String?   @db.VarChar(255)
  phone          String?   @db.VarChar(20)
  street         String?   @db.VarChar(255)
  city           String?   @db.VarChar(100)
  postalCode     String?   @map("postal_code") @db.VarChar(10)
  province       String?   @db.VarChar(100)
  country        String?   @db.VarChar(5)
  notes          String?   @db.Text
  language       String?   @default("es") @db.VarChar(10)
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator       User?              @relation("ClientCreatedBy", fields: [createdBy], references: [id])
  bookings      Booking[]
  guestSlots    BookingGuest[]
  evaluations   ClientEvaluation[]
  policeReports PoliceReport[]

  @@index([organizationId])
  @@index([dniPassport, organizationId])
  @@map("clients")
}

model Booking {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  clientId       String?  @map("client_id") @db.Uuid
  propertyId     String   @map("property_id") @db.Uuid
  checkInDate    DateTime @map("check_in_date") @db.Date
  checkOutDate   DateTime @map("check_out_date") @db.Date
  totalAmount    Decimal? @map("total_amount") @db.Decimal(10, 2)
  status         String   @default("created") @db.VarChar(20)
  source         String   @default("direct") @db.VarChar(20)
  externalId     String?  @map("external_id") @db.VarChar(255)
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client        Client?            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  property      Property           @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  creator       User?              @relation("BookingCreatedBy", fields: [createdBy], references: [id])
  guests        BookingGuest[]
  evaluation    ClientEvaluation?
  financials    Financial[]
  policeReports PoliceReport[]

  payments      BookingPayment[]

  @@index([propertyId, checkInDate, checkOutDate])
  @@index([clientId])
  contracts     Contract[]
  guestsSes    BookingGuestSes[]
  sesLote       String?   @map("ses_lote") @db.VarChar(50)
  sesStatus     String?   @map("ses_status") @db.VarChar(20)
  sesError      String?   @map("ses_error") @db.Text
  sesSentAt     DateTime? @map("ses_sent_at")
  checkinToken  String?   @unique @map("checkin_token") @db.VarChar(64)
  checkinStatus String?   @map("checkin_status") @db.VarChar(20)
  checkinSentAt DateTime? @map("checkin_sent_at")
  checkinDoneAt DateTime? @map("checkin_done_at")
  welcomeSentAt DateTime? @map("welcome_sent_at")
  statusChangedAt  DateTime?
  statusHistory    BookingStatusHistory[]
  notes         String?   @db.Text

  @@map("bookings")
}

model BookingGuest {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  role      String   @default("guest") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")

  booking      Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  policeReport PoliceReport?

  @@unique([bookingId, clientId])
  @@index([bookingId])
  @@map("booking_guests")
}

model ClientEvaluation {
  id                 String   @id @default(uuid()) @db.Uuid
  bookingId          String   @unique @map("booking_id") @db.Uuid
  clientId           String   @map("client_id") @db.Uuid
  score              Int
  cleanlinessScore   Int      @map("cleanliness_score")
  behaviourScore     Int      @map("behaviour_score")
  paymentPunctuality Int      @map("payment_punctuality")
  notes              String?  @db.Text
  evaluatedBy        String?  @map("evaluated_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  evaluator User?   @relation(fields: [evaluatedBy], references: [id])

  @@index([clientId])
  @@map("client_evaluations")
}

model FinancialCategory {
  id             Int      @id @default(autoincrement())
  organizationId String   @map("organization_id") @db.Uuid
  type           String   @db.VarChar(10)
  name           String   @db.VarChar(100)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  financials   Financial[]

  @@unique([organizationId, type, name])
  @@map("financial_categories")
}

model Financial {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  propertyId     String?  @map("property_id") @db.Uuid
  bookingId      String?  @map("booking_id") @db.Uuid
  categoryId     Int      @map("category_id")
  type           String   @db.VarChar(10)
  amount         Decimal  @db.Decimal(10, 2)
  description    String?  @db.Text
  date           DateTime @db.Date
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  booking      Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  category     FinancialCategory @relation(fields: [categoryId], references: [id])
  creator      User?             @relation("FinancialCreatedBy", fields: [createdBy], references: [id])

  @@index([propertyId, date])
  @@index([organizationId, date])
  @@map("financials")
}

model PoliceReport {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  bookingId      String   @map("booking_id") @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  bookingGuestId String?  @unique @map("booking_guest_id") @db.Uuid
  reportDate     DateTime @map("report_date") @db.Date
  status         String   @default("pending") @db.VarChar(20)
  sesReferenceId String?  @map("ses_reference_id") @db.VarChar(255)
  sentBy         String?  @map("sent_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client       Client               @relation(fields: [clientId], references: [id], onDelete: Restrict)
  bookingGuest BookingGuest?        @relation(fields: [bookingGuestId], references: [id])
  sender       User?                @relation("PoliceReportSentBy", fields: [sentBy], references: [id])
  payload      PoliceReportPayload?

  @@index([status, reportDate])
  @@index([bookingId])
  @@map("police_reports")
}

model PoliceReportPayload {
  id             String   @id @default(uuid()) @db.Uuid
  policeReportId String   @unique @map("police_report_id") @db.Uuid
  requestXml     String?  @map("request_xml") @db.Text
  responseXml    String?  @map("response_xml") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  policeReport PoliceReport @relation(fields: [policeReportId], references: [id], onDelete: Cascade)

  @@map("police_report_payloads")
}

model AuditLog {
  id             BigInt   @id @default(autoincrement())
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String   @db.VarChar(100)
  entityType     String   @map("entity_type") @db.VarChar(50)
  entityId       String   @map("entity_id") @db.Uuid
  oldValues      Json?    @map("old_values")
  newValues      Json?    @map("new_values")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model AvailabilitySync {
  id             String    @id @default(uuid()) @db.Uuid
  propertyId     String    @map("property_id") @db.Uuid
  platform       String    @db.VarChar(30)
  icalUrl        String?   @map("ical_url") @db.Text
  exportToken    String?   @map("export_token") @db.VarChar(64)
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncStatus String    @default("pending") @map("last_sync_status")
  lastSyncError  String?   @map("last_sync_error") @db.Text
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  property Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  blocks   AvailabilityBlock[]

  @@unique([propertyId, platform])
  @@index([propertyId])
  @@map("availability_syncs")
}

model AvailabilityBlock {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  syncId      String?  @map("sync_id") @db.Uuid
  externalUid String?  @map("external_uid") @db.VarChar(255)
  summary     String?  @db.VarChar(255)
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  source      String   @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  property Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sync     AvailabilitySync? @relation(fields: [syncId], references: [id], onDelete: SetNull)

  @@unique([propertyId, externalUid])
  @@index([propertyId, startDate, endDate])
  @@map("availability_blocks")
}

model ContractTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  type           String   @db.VarChar(50)
  content        String   @db.Text
  ownerName      String   @map("owner_name") @db.VarChar(255)
  ownerNif       String   @map("owner_nif") @db.VarChar(20)
  ownerAddress   String?  @map("owner_address") @db.Text
  ownerSignature     String?  @map("owner_signature") @db.Text
  depositAmount  Decimal? @map("deposit_amount") @db.Decimal(10, 2)
  clauses        String?  @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contracts    Contract[]

  @@index([organizationId])
  @@map("contract_templates")
}

model Contract {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  bookingId      String    @map("booking_id") @db.Uuid
  templateId     String    @map("template_id") @db.Uuid
  status         String    @default("draft") @db.VarChar(20)
  token          String    @unique @db.VarChar(64)
  pdfPath        String?   @map("pdf_path") @db.VarChar(500)
  signatureImage String?   @map("signature_image") @db.Text
  signerIp       String?   @map("signer_ip") @db.VarChar(45)
  signerName     String?   @map("signer_name") @db.VarChar(255)
  depositAmount  Decimal?  @map("deposit_amount") @db.Decimal(10, 2)
  paperlessDocumentId Int?      @map("paperless_document_id")
  sentAt         DateTime? @map("sent_at")
  signedAt       DateTime? @map("signed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  booking      Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  template     ContractTemplate @relation(fields: [templateId], references: [id])

  @@index([bookingId])
  @@index([token])
  @@map("contracts")
}

model BookingGuestSes {
  id              String   @id @default(uuid()) @db.Uuid
  bookingId       String   @map("booking_id") @db.Uuid
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  docType         String   @map("doc_type") @db.VarChar(20)
  docNumber       String   @map("doc_number") @db.VarChar(30)
  docCountry      String   @map("doc_country") @db.VarChar(5)
  birthDate       DateTime? @map("birth_date") @db.Date
  phone           String?  @db.VarChar(30)
  street          String?  @db.VarChar(255)
  city            String?  @db.VarChar(100)
  postalCode      String?  @map("postal_code") @db.VarChar(10)
  province        String?  @db.VarChar(100)
  country         String?  @db.VarChar(5)
  createdAt       DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_guests_ses")
}

model BookingPayment {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @map("booking_id") @db.Uuid
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  concept   String   @db.VarChar(30)
  amount    Float
  date      DateTime @db.Date
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@map("booking_payments")
}

model BookingStatusHistory {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @db.Uuid
  fromStatus String?
  toStatus   String
  changedBy  String
  reason     String?
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PropertyContent {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  propertyId     String?   @map("property_id") @db.Uuid
  template       String?   @db.Text
  translations   Json      @default("{}") @map("translations")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property?     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([organizationId, propertyId])
  @@index([organizationId])
  @@map("property_contents")
}

model PropertyRules {
  id                 String   @id @default(uuid()) @db.Uuid
  propertyId         String   @unique @map("property_id") @db.Uuid
  organizationId     String   @map("organization_id") @db.Uuid
  baseLanguage       String   @default("es") @map("base_language") @db.VarChar(10)
  baseContent        String   @map("base_content") @db.Text
  translations       Json     @default("{}")
  translationsEdited Json     @default("[]") @map("translations_edited")
  updatedAt          DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_rules")
}

model PropertyDocument {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  propertyId     String?  @map("property_id") @db.Uuid
  name           String   @db.VarChar(255)
  fileData       String   @map("file_data") @db.Text
  fileSize       Int      @map("file_size")
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property?    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("property_documents")
}

model RecurringExpense {
  id             String    @id @default(uuid()) @db.Uuid
  propertyId     String    @map("property_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  type           String    @db.VarChar(20)
  amount         Float
  deductible     Boolean   @default(false)
  frequency      String    @db.VarChar(20)
  dayOfMonth     Int       @map("day_of_month")
  notes          String?   @db.Text
  active         Boolean   @default(true)
  nextRunDate    DateTime  @map("next_run_date") @db.Date
  lastRunDate    DateTime? @map("last_run_date") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, active, nextRunDate])
  @@map("recurring_expenses")
}

model Material {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  type          String   @db.VarChar(20)
  unit          String   @db.VarChar(20)
  barcode       String   @unique @db.VarChar(20)
  standardPrice Float    @map("standard_price")
  minStock      Float    @default(0) @map("min_stock")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  movements StockMovement[]

  @@map("materials")
}

model StockMovement {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @map("property_id") @db.Uuid
  materialId String   @map("material_id") @db.Uuid
  type       String   @db.VarChar(20)
  quantity   Float
  unitPrice  Float    @map("unit_price")
  notes      String?  @db.Text
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  material Material  @relation(fields: [materialId], references: [id], onDelete: Restrict)
  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([propertyId, materialId])
  @@index([materialId])
  @@map("stock_movements")
}
