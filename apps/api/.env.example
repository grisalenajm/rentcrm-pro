# =============================================================================
# RentalSuite API — Environment Variables
# =============================================================================
# This file documents all variables consumed by the NestJS API.
# For Docker Compose deployments, copy the root .env.example to .env instead.
# This file is used when running Prisma CLI directly from the host:
#
#   cp apps/api/.env.example apps/api/.env
#   # Set DATABASE_URL to use localhost:5432 (not the Docker hostname)
#   cd apps/api && npx prisma migrate dev
# =============================================================================


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# When running from the host, use localhost:5432 instead of the Docker hostname.
# Example (host): postgresql://rentcrm:CHANGE_ME@localhost:5432/rentcrm
# Example (Docker): postgresql://rentcrm:CHANGE_ME@postgres:5432/rentcrm
DATABASE_URL=postgresql://rentcrm:CHANGE_ME@localhost:5432/rentcrm

POSTGRES_DB=rentcrm
POSTGRES_USER=rentcrm
POSTGRES_PASSWORD=CHANGE_ME          # generate: openssl rand -hex 32


# ── Redis ─────────────────────────────────────────────────────────────────────
# Use localhost:6379 when running the API outside Docker.
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME             # generate: openssl rand -hex 32


# ── Authentication (JWT) ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME                 # generate: openssl rand -hex 64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME        # generate: openssl rand -hex 64
JWT_REFRESH_EXPIRES_IN=7d


# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001

# Public URL of the frontend — used for CORS and email links.
FRONTEND_URL=http://localhost:3000

# Public URL of the API — used by CheckinPage and other browser-direct calls.
VITE_API_URL=http://localhost:3001


# ── LibreTranslate ────────────────────────────────────────────────────────────
# Use localhost:5000 when LibreTranslate runs outside Docker.
LIBRETRANSLATE_URL=http://localhost:5000


# ── SMTP (Email) ──────────────────────────────────────────────────────────────
# Required for check-in emails, contract delivery, and recurring-expense alerts.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=RentalSuite <no-reply@example.com>


# ── API Public URL ────────────────────────────────────────────────────────────
# Externally reachable URL of the API (with https:// when behind a reverse proxy).
# Used for Paperless-ngx webhook callbacks, check-in email links, and any context
# where the API must be reachable from outside the Docker network.
API_PUBLIC_URL=https://YOUR_DOMAIN


# ── Paperless-ngx (optional) ──────────────────────────────────────────────────
# Signed contracts are uploaded automatically when these are set.
PAPERLESS_URL=https://paperless.example.com
PAPERLESS_TOKEN=CHANGE_ME
